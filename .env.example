# Database
AIART_DB_URL=jdbc:mysql://localhost:3306/aiart_codex_platform?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
AIART_DB_USER=root
AIART_DB_PASSWORD=replace_with_your_database_password

# Redis
AIART_REDIS_HOST=localhost
AIART_REDIS_PORT=6379

# Authentication: replace with a random value of at least 32 bytes
AIART_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_bytes
AIART_JWT_EXPIRATION_SECONDS=604800

# Forge / Stable Diffusion WebUI-compatible API
AIART_SD_BASE_URL=http://127.0.0.1:7860
AIART_SD_TIMEOUT_SECONDS=300

# Uploaded and generated files
AIART_STORAGE_PROVIDER=local
AIART_UPLOAD_ROOT=uploads
AIART_MAX_ASSET_BYTES=104857600
AIART_DOWNLOAD_EXPIRY_SECONDS=300

# MinIO/S3-compatible object storage (required when AIART_STORAGE_PROVIDER=minio)
AIART_MINIO_ENDPOINT=http://127.0.0.1:9000
AIART_MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
AIART_MINIO_ACCESS_KEY=artforge
AIART_MINIO_SECRET_KEY=replace_with_a_long_minio_secret
AIART_MINIO_BUCKET=artforge

# Browser origins allowed to call the API, separated by commas
AIART_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# Failed-login protection
AIART_LOGIN_MAX_ATTEMPTS=5
AIART_LOGIN_WINDOW_SECONDS=900
