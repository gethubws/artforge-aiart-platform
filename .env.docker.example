# Copy this file to .env.docker before starting Docker Compose.
# Never commit the copied file.

AIART_DB_PASSWORD=replace_with_a_strong_database_password
AIART_DB_ROOT_PASSWORD=replace_with_a_different_root_password
AIART_JWT_SECRET=replace_with_at_least_32_random_bytes

AIART_MINIO_ACCESS_KEY=artforge
AIART_MINIO_SECRET_KEY=replace_with_a_long_minio_secret
AIART_MINIO_BUCKET=artforge
AIART_MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
AIART_STORAGE_PROVIDER=minio
AIART_DOWNLOAD_EXPIRY_SECONDS=300

AIART_HTTP_PORT=5174
AIART_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5174
AIART_SD_BASE_URL=http://host.docker.internal:7860
AIART_SD_TIMEOUT_SECONDS=300
